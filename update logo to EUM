<script>
  // build waveform bars: two groups merging visually
  const row = document.getElementById('waveRow');
  const n = 36;
  for(let i=0;i<n;i++){
    const bar = document.createElement('div');
    bar.className = 'bar' + (i >= n/2 ? ' right' : '');
    const h = 16 + Math.round(Math.sin(i/2)*14) + Math.round(Math.random()*10);
    bar.style.height = h + 'px';
    bar.style.animationDelay = (i*0.045) + 's';
    row.appendChild(bar);
  }

  // scroll reveal
  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); } });
  },{threshold:0.15});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>

